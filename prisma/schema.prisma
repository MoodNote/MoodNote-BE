// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum NotificationType {
  SYSTEM
  REMINDER
  STREAK
}

enum InputMethod {
  TEXT
  VOICE
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EmotionType {
  Enjoyment
  Sadness
  Anger
  Fear
  Disgust
  Surprise
  Other
}

enum RecommendationMode {
  MIRROR
  SHIFT
}

enum MusicStatus {
  PENDING      // Waiting for analysis to complete, not yet started
  GENERATING   // Auto-generation is in progress (fire-and-forget running)
  COMPLETED    // Successfully generated
  FAILED       // Generation failed — user can retry via refresh endpoint
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

// ─────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  username            String              @unique
  name                String
  password            String
  role                UserRole            @default(USER)
  isEmailVerified     Boolean             @default(false)
  isActive            Boolean             @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relations
  refreshTokens        RefreshToken[]
  moodEntries          MoodEntry[]
  notifications        Notification[]
  notificationSettings NotificationSettings?
  deviceTokens         DeviceToken[]
  userSettings         UserSettings?
  userStats            UserStats?
  playlists            Playlist[]
  musicRecommendations MusicRecommendation[]
  trackPlays           TrackPlay[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// USER SETTINGS & NOTIFICATIONS
// ─────────────────────────────────────────

model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  theme     Theme    @default(SYSTEM)
  language  String   @default("vi")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model UserStats {
  userId        String   @id @map("user_id")
  writingStreak Int      @default(0) @map("writing_streak")
  smileStreak   Int      @default(0) @map("smile_streak")
  sadStreak     Int      @default(0) @map("sad_streak")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_stats")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String           @db.Text
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationSettings {
  id              String   @id @default(uuid())
  userId          String   @unique
  reminderEnabled Boolean  @default(true)
  reminderTime    String   @default("21:00")
  reminderDays    Int[]    @default([1, 2, 3, 4, 5, 6, 7])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ─────────────────────────────────────────
// JOURNAL
// ─────────────────────────────────────────

// Note: there is no separate `title` column. Title is embedded inside the
// encrypted JSON payload (see EntryPayload in entry.service.ts).
model MoodEntry {
  id               String         @id @default(uuid())
  userId           String
  encryptedContent String         @db.Text // JSON: { title, content (Quill Delta) }, AES-256-CBC encrypted
  contentIv        String
  wordCount        Int            @default(0)
  entryDate        DateTime
  inputMethod      InputMethod    @default(TEXT)
  tags             String[]       @default([])
  isPrivate        Boolean        @default(false)
  analysisStatus   AnalysisStatus @default(PENDING)
  musicStatus      MusicStatus    @default(PENDING) @map("music_status")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  emotionAnalysis  EmotionAnalysis?
  recommendations  MusicRecommendation[]

  @@index([userId])
  @@index([userId, entryDate])
  @@index([userId, createdAt])
  @@index([analysisStatus])
  @@index([musicStatus])
  @@map("mood_entries")
}

model EmotionAnalysis {
  id                  String      @id @default(uuid())
  entryId             String      @unique @map("entry_id")
  primaryEmotion      EmotionType @map("primary_emotion")
  sentimentScore      Float       @map("sentiment_score")
  intensity           Float
  confidence          Float?      @map("confidence")
  emotionDistribution Json?       @map("emotion_distribution")
  keywords            String[]    @default([])
  modelVersion        String?     @map("model_version")
  analyzedAt          DateTime    @default(now()) @map("analyzed_at")
  createdAt           DateTime    @default(now()) @map("created_at")

  entry MoodEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([primaryEmotion])
  @@index([sentimentScore])
  @@map("emotion_analyses")
}

// ─────────────────────────────────────────
// MUSIC CATALOG
// ─────────────────────────────────────────

model Artist {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tracks TrackArtist[]

  @@index([name])
  @@map("artists")
}

model Genre {
  id   String @id @default(uuid())
  name String @unique

  tracks TrackGenre[]

  @@index([name])
  @@map("genres")
}

model Track {
  id               String   @id @default(uuid())
  trackName        String   @map("track_name")
  albumName        String?  @map("album_name")
  popularity       Int?
  isExplicit       Boolean  @default(false) @map("is_explicit")
  durationMs       Int?     @map("duration_ms")
  danceability     Float?
  energy           Float?
  key              Int?
  loudness         Float?
  speechiness      Float?
  acousticness     Float?
  instrumentalness Float?
  liveness         Float?
  valence          Float?
  tempo            Float?
  lyrics           String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  artists              TrackArtist[]
  genres               TrackGenre[]
  recommendationTracks RecommendationTrack[]
  playlistTracks       PlaylistTrack[]
  trackPlays           TrackPlay[]

  @@index([popularity])
  @@index([valence])
  @@index([energy])
  @@map("tracks")
}

model TrackArtist {
  trackId  String  @map("track_id")
  artistId String  @map("artist_id")
  role     String?

  track  Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([trackId, artistId])
  @@index([trackId])
  @@index([artistId])
  @@map("track_artists")
}

model TrackGenre {
  trackId String @map("track_id")
  genreId String @map("genre_id")

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([trackId, genreId])
  @@index([trackId])
  @@index([genreId])
  @@map("track_genres")
}

// ─────────────────────────────────────────
// RECOMMENDATIONS
// ─────────────────────────────────────────

model MusicRecommendation {
  id          String             @id @default(uuid())
  entryId     String             @map("entry_id")
  userId      String             @map("user_id")
  mode        RecommendationMode
  generatedAt DateTime           @default(now()) @map("generated_at")
  createdAt   DateTime           @default(now()) @map("created_at")

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry  MoodEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tracks RecommendationTrack[]

  @@unique([entryId, mode])
  @@index([entryId])
  @@index([userId])
  @@index([userId, generatedAt])
  @@map("music_recommendations")
}

model RecommendationTrack {
  recommendationId String @map("recommendation_id")
  trackId          String @map("track_id")
  order            Int

  recommendation MusicRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  track          Track               @relation(fields: [trackId], references: [id], onDelete: Restrict)

  @@id([recommendationId, trackId])
  @@index([recommendationId])
  @@index([trackId])
  @@map("recommendation_tracks")
}

// ─────────────────────────────────────────
// PLAYLISTS
// ─────────────────────────────────────────

model Playlist {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  name           String
  associatedMood EmotionType? @map("associated_mood")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]

  @@index([userId])
  @@map("playlists")
}

model PlaylistTrack {
  playlistId String @map("playlist_id")
  trackId    String @map("track_id")
  order      Int

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Restrict)

  @@id([playlistId, trackId])
  @@index([playlistId])
  @@index([trackId])
  @@map("playlist_tracks")
}

// ─────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────

model TrackPlay {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  trackId  String   @map("track_id")
  playedAt DateTime @default(now()) @map("played_at")
  context  String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trackId])
  @@index([userId, playedAt])
  @@index([trackId, playedAt])
  @@map("track_plays")
}
