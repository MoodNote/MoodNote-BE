// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum NotificationType {
  SYSTEM
  REMINDER
  STREAK
}

enum InputMethod {
  TEXT
  VOICE
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum EmotionType {
  HAPPY
  SAD
  ANGRY
  ANXIOUS
  FEARFUL
  NEUTRAL
}

enum RecommendationMode {
  MIRROR
  SHIFT
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

// ─────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  username            String              @unique
  name                String
  password            String
  role                UserRole            @default(USER)
  isEmailVerified     Boolean             @default(false)
  isActive            Boolean             @default(true)
  failedLoginAttempts Int                 @default(0)
  lockoutUntil        DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relations
  emailVerifications   EmailVerification[]
  passwordResets       PasswordReset[]
  refreshTokens        RefreshToken[]
  moodEntries          MoodEntry[]
  notifications        Notification[]
  notificationSettings NotificationSettings?
  deviceTokens         DeviceToken[]
  userSettings         UserSettings?
  playlists            Playlist[]
  musicRecommendations MusicRecommendation[]
  trackPlays           TrackPlay[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@map("users")
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("email_verifications")
}

model PasswordReset {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  isUsed     Boolean  @default(false)
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────
// USER SETTINGS & NOTIFICATIONS
// ─────────────────────────────────────────

model UserSettings {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  theme     Theme    @default(SYSTEM)
  language  String   @default("vi")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String           @db.Text
  type      NotificationType @default(SYSTEM)
  isRead    Boolean          @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationSettings {
  id              String   @id @default(uuid())
  userId          String   @unique
  reminderEnabled Boolean  @default(true)
  reminderTime    String   @default("21:00")
  reminderDays    Int[]    @default([1, 2, 3, 4, 5, 6, 7])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ─────────────────────────────────────────
// JOURNAL
// ─────────────────────────────────────────

model MoodEntry {
  id               String         @id @default(uuid())
  userId           String
  encryptedContent String         @db.Text
  contentIv        String
  wordCount        Int            @default(0)
  entryDate        DateTime
  inputMethod      InputMethod    @default(TEXT)
  tags             String[]       @default([])
  isPrivate        Boolean        @default(false)
  analysisStatus   AnalysisStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  emotionAnalysis  EmotionAnalysis?
  recommendations  MusicRecommendation[]

  @@index([userId])
  @@index([userId, entryDate])
  @@index([userId, createdAt])
  @@index([analysisStatus])
  @@map("mood_entries")
}

model EmotionAnalysis {
  id             String      @id @default(uuid())
  entryId        String      @unique @map("entry_id")
  primaryEmotion EmotionType @map("primary_emotion")
  sentimentScore Float       @map("sentiment_score")
  intensity      Int
  modelVersion   String?     @map("model_version")
  analyzedAt     DateTime    @default(now()) @map("analyzed_at")
  createdAt      DateTime    @default(now()) @map("created_at")

  entry    MoodEntry      @relation(fields: [entryId], references: [id], onDelete: Cascade)
  keywords EntryKeyword[]

  @@index([entryId])
  @@index([primaryEmotion])
  @@index([sentimentScore])
  @@map("emotion_analyses")
}

model EntryKeyword {
  id         String  @id @default(uuid())
  analysisId String  @map("analysis_id")
  keyword    String
  relevance  Float

  analysis EmotionAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([keyword])
  @@map("entry_keywords")
}

// ─────────────────────────────────────────
// MUSIC CATALOG
// ─────────────────────────────────────────

model Artist {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tracks TrackArtist[]

  @@index([name])
  @@map("artists")
}

model Genre {
  id   String @id @default(uuid())
  name String @unique

  tracks TrackGenre[]

  @@index([name])
  @@map("genres")
}

model Track {
  id               String   @id @default(uuid())
  trackName        String   @map("track_name")
  albumName        String?  @map("album_name")
  popularity       Int?
  isExplicit       Boolean  @default(false) @map("is_explicit")
  durationMs       Int?     @map("duration_ms")
  danceability     Float?
  energy           Float?
  key              Int?
  loudness         Float?
  speechiness      Float?
  acousticness     Float?
  instrumentalness Float?
  liveness         Float?
  valence          Float?
  tempo            Float?
  lyrics           String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  artists              TrackArtist[]
  genres               TrackGenre[]
  recommendationTracks RecommendationTrack[]
  playlistTracks       PlaylistTrack[]
  trackPlays           TrackPlay[]

  @@index([popularity])
  @@index([valence])
  @@index([energy])
  @@map("tracks")
}

model TrackArtist {
  trackId  String  @map("track_id")
  artistId String  @map("artist_id")
  role     String?

  track  Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([trackId, artistId])
  @@index([trackId])
  @@index([artistId])
  @@map("track_artists")
}

model TrackGenre {
  trackId String @map("track_id")
  genreId String @map("genre_id")

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)
  genre Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([trackId, genreId])
  @@index([trackId])
  @@index([genreId])
  @@map("track_genres")
}

// ─────────────────────────────────────────
// RECOMMENDATIONS
// ─────────────────────────────────────────

model MusicRecommendation {
  id          String             @id @default(uuid())
  entryId     String             @map("entry_id")
  userId      String             @map("user_id")
  mode        RecommendationMode
  generatedAt DateTime           @default(now()) @map("generated_at")
  createdAt   DateTime           @default(now()) @map("created_at")

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  entry  MoodEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  tracks RecommendationTrack[]

  @@unique([entryId, mode])
  @@index([entryId])
  @@index([userId])
  @@index([userId, generatedAt])
  @@map("music_recommendations")
}

model RecommendationTrack {
  recommendationId String @map("recommendation_id")
  trackId          String @map("track_id")
  order            Int

  recommendation MusicRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  track          Track               @relation(fields: [trackId], references: [id], onDelete: Restrict)

  @@id([recommendationId, trackId])
  @@index([recommendationId])
  @@index([trackId])
  @@map("recommendation_tracks")
}

// ─────────────────────────────────────────
// PLAYLISTS
// ─────────────────────────────────────────

model Playlist {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  name           String
  associatedMood EmotionType? @map("associated_mood")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]

  @@index([userId])
  @@map("playlists")
}

model PlaylistTrack {
  playlistId String @map("playlist_id")
  trackId    String @map("track_id")
  order      Int

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Restrict)

  @@id([playlistId, trackId])
  @@index([playlistId])
  @@index([trackId])
  @@map("playlist_tracks")
}

// ─────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────

model TrackPlay {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  trackId  String   @map("track_id")
  playedAt DateTime @default(now()) @map("played_at")
  context  String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([trackId])
  @@index([userId, playedAt])
  @@index([trackId, playedAt])
  @@map("track_plays")
}
